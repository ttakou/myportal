# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Root domain for tenant subdomain routing (no port).
# Dev: "localhost" → visit acme.localhost:3000. Prod: "mportals.com".
NEXT_PUBLIC_ROOT_DOMAIN=localhost

# Server-only (never expose to the browser). Used for admin/back-office tasks,
# including the emergency (EESS) Web Push fan-out which must bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push / VAPID — powers real emergency alert delivery (EESS).
# Generate a P-256 keypair (e.g. `npx web-push generate-vapid-keys`).
# The public key is safe to expose; the private key and subject are server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:safety@yourcompany.com
